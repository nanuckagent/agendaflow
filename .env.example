# ────────────────────────────────────────────────────────────────────────────
# AgendaFlow Environment Variables
# ────────────────────────────────────────────────────────────────────────────
# Copy to .env.development (local) or .env.production (deploy)

# ────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_ROLE=api
APP_VERSION=0.1.0
APP_NAME=AgendaFlow

# ────────────────────────────────────────────────────────────────────────────
# DATABASE
# ────────────────────────────────────────────────────────────────────────────
POSTGRES_DB=agendaflow
POSTGRES_USER=agendaflow
POSTGRES_PASSWORD=changeme123!
DATABASE_URL=postgresql://agendaflow:changeme123!@localhost:5432/agendaflow

# ────────────────────────────────────────────────────────────────────────────
# REDIS
# ────────────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme123!
REDIS_URL=redis://:changeme123!@localhost:6379

# ────────────────────────────────────────────────────────────────────────────
# JWT & SECURITY
# ────────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
JWT_EXPIRES_IN=7d
SESSION_SECRET=your-session-secret-change-me-in-production

# ────────────────────────────────────────────────────────────────────────────
# API & FRONTEND
# ────────────────────────────────────────────────────────────────────────────
API_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000
VITE_APP_ENV=development

# ────────────────────────────────────────────────────────────────────────────
# LOGGING
# ────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ────────────────────────────────────────────────────────────────────────────
# SMTP (Optional, for email notifications)
# ────────────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@agendaflow.local

# ────────────────────────────────────────────────────────────────────────────
# EXTERNAL INTEGRATIONS (Phase 2+)
# ────────────────────────────────────────────────────────────────────────────
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# OUTLOOK_CLIENT_ID=
# OUTLOOK_CLIENT_SECRET=
# SLACK_BOT_TOKEN=
