{
  "name": "agendaflow-backend",
  "version": "0.1.0",
  "description": "AgendaFlow — Node 20 + Hono + Drizzle + PostgreSQL + Redis",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node --enable-source-maps dist/backend/src/index.js",
    "start:worker": "APP_ROLE=worker node --enable-source-maps dist/backend/src/index.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --runInBand",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/db/seed.ts",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@hono/node-server": "^1.11.1",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.46.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@sentry/node": "^8.0.0",
    "argon2": "^0.31.2",
    "bullmq": "^5.7.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "google-auth-library": "^9.14.1",
    "hono": "^4.3.4",
    "ioredis": "^5.3.2",
    "jose": "^5.2.4",
    "mercadopago": "^2.1.0",
    "nodemailer": "^6.9.13",
    "pg": "^8.11.3",
    "pino": "^9.1.0",
    "pino-http": "^10.0.0",
    "pino-pretty": "^11.0.0",
    "postgres": "^3.4.3",
    "rate-limiter-flexible": "^5.0.3",
    "twilio": "^4.19.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "drizzle-kit": "^0.21.4",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "pino-pretty": "^11.0.0",
    "ts-jest": "^29.1.4",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.11.2",
    "typescript": "^5.4.5"
  }
}
